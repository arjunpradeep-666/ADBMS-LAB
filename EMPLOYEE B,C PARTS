STEP(B)
-------
CREATE OR REPLACE PROCEDURE PR2
(
  P_ENO IN EMPLOYEE.ENO%TYPE,
  P_COMM OUT NUMBER
)
AS
BEGIN
  SELECT SAL * 0.10
  INTO P_COMM
  FROM EMPLOYEE
  WHERE ENO = P_ENO;
END;
/

STEP(C)
-------
DECLARE 
N EMPLOYEE.ENO%TYPE := &N;
COMM NUMBER;
BEGIN
PR2(N, COMM);
DBMS_OUTPUT.PUT_LINE('COMMISSION IS '||COMM);
END;
/
